generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  avatarUrl   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  supabaseUid String    @unique
  companies   Company[]

  @@index([email])
  @@index([supabaseUid])
}

model Company {
  id                            String                    @id @default(cuid())
  name                          String
  registrationNumber            String
  taxId                         String
  address                       Json?
  userId                        String
  stripeCustomerId              String?
  stripeSubscriptionId          String?
  subscriptionTier              Tier                      @default(FREE)
  subscriptionStatus            StripeSubscriptionStatus? @default(INACTIVE)
  subscriptionCurrentPeriodEnd  DateTime?
  subscriptionCancelAtPeriodEnd Boolean                   @default(false)
  status                        CompanyStatus             @default(ACTIVE)
  createdAt                     DateTime                  @default(now())
  updatedAt                     DateTime                  @updatedAt
  user                          User                      @relation(fields: [userId], references: [id])
  employees                     Employee[]
  payrollRuns                   PayrollRun[]

  @@index([userId])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model Employee {
  id             String         @id @default(cuid())
  firstName      String
  lastName       String
  email          String
  iban           String
  taxId          String?
  employmentType EmploymentType
  salaryGross    Decimal        @default(0)
  startDate      DateTime
  endDate        DateTime?
  companyId      String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  encVersion     String         @default("v1")
  benefits       Benefit[]
  company        Company        @relation(fields: [companyId], references: [id])
  payrollEntries PayrollEntry[]

  @@index([companyId])
  @@index([email])
}

model PayrollRun {
  id                  String         @id @default(cuid())
  periodStart         DateTime
  periodEnd           DateTime
  status              PayrollStatus
  companyId           String
  submissionReference String?
  submittedAt         DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  entries             PayrollEntry[]
  company             Company        @relation(fields: [companyId], references: [id])

  @@unique([companyId, periodStart, periodEnd])
  @@index([companyId])
  @@index([status])
}

model PayrollEntry {
  id             String         @id @default(cuid())
  payrollRunId   String
  employeeId     String
  salaryGross    Decimal
  tax            Decimal
  socialSecurity Decimal
  netPay         Decimal
  totalCost      Decimal
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  contributions  Contribution[]
  employee       Employee       @relation(fields: [employeeId], references: [id])
  payrollRun     PayrollRun     @relation(fields: [payrollRunId], references: [id])

  @@unique([payrollRunId, employeeId])
  @@index([payrollRunId])
}

model Contribution {
  id             String           @id @default(cuid())
  payrollEntryId String
  type           ContributionType
  amount         Decimal
  description    String
  createdAt      DateTime         @default(now())
  payrollEntry   PayrollEntry     @relation(fields: [payrollEntryId], references: [id])
}

model Benefit {
  id            String      @id @default(cuid())
  employeeId    String
  type          BenefitType
  value         Decimal
  effectiveDate DateTime
  endDate       DateTime?
  createdAt     DateTime    @default(now())
  employee      Employee    @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

model TaxBracket {
  id            String    @id @default(cuid())
  year          Int
  minIncome     Decimal
  maxIncome     Decimal?
  rate          Decimal
  effectiveFrom DateTime
  effectiveTo   DateTime?

  @@unique([year, minIncome])
  @@index([year])
}

model SocialSecurityRate {
  id               String    @id @default(cuid())
  year             Int       @unique
  employeeRate     Decimal
  employerRate     Decimal
  maxWeeklyEarning Decimal
  effectiveFrom    DateTime
  effectiveTo      DateTime?

  @@index([year])
}

model Optimization {
  id              String             @id @default(cuid())
  companyId       String
  suggestedAt     DateTime           @default(now())
  type            OptimizationType
  description     String
  estimatedSaving Decimal
  status          OptimizationStatus @default(PENDING)
  appliedAt       DateTime?
  employeeId      String?

  @@index([companyId])
  @@index([status])
}

model AuditEvent {
  id         String   @id @default(cuid())
  companyId  String
  userId     String?
  action     String
  resource   String?
  resourceId String?
  metadata   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([companyId])
  @@index([createdAt])
}

enum Tier {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum StripeSubscriptionStatus {
  INACTIVE
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  TRIALING
  INCOMPLETE
  INCOMPLETE_EXPIRED
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum PayrollStatus {
  DRAFT
  CALCULATED
  SUBMITTED
  PAID
  CANCELLED
}

enum ContributionType {
  MSSS_EMPLOYEE
  MSSS_EMPLOYER
  BONUS_TAXABLE
  BONUS_TAX_EXEMPT
  MEAL_ALLOWANCE
  TRAVEL_ALLOWANCE
  CAR_ALLOWANCE
  OTHER_ALLOWANCE
  UNION_FEE
  INSURANCE_PREMIUM
}

enum BenefitType {
  CAR_ALLOWANCE
  MEAL_ALLOWANCE
  TRANSPORT
  MOBILE
  HOUSING
  EDUCATION
  BONUS
  COMMISSION
  MEDICAL_INSURANCE
  PENSION_CONTRIBUTION
}

enum OptimizationType {
  TAX_LOSS_HARVESTING
  BENEFIT_RESTRUCTURE
  BONUS_TIMING
  PENSION_TOPUP
  SSF_CHOICE
}

enum OptimizationStatus {
  PENDING
  ACCEPTED
  REJECTED
  APPLIED
}
